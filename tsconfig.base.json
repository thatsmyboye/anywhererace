{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@anywhererace/core": ["packages/core/src/index.ts"],
      "@anywhererace/core/*": ["packages/core/src/*"],
      "@anywhererace/sim": ["packages/sim/src/index.ts"],
      "@anywhererace/sim/*": ["packages/sim/src/*"],
      "@anywhererace/championship": ["packages/championship/src/index.ts"],
      "@anywhererace/championship/*": ["packages/championship/src/*"],
      "@anywhererace/track": ["packages/track/src/index.ts"],
      "@anywhererace/track/*": ["packages/track/src/*"],
      "@anywhererace/worker": ["packages/worker/src/index.ts"],
      "@anywhererace/worker/*": ["packages/worker/src/*"],
      "@anywhererace/store": ["packages/store/src/index.ts"],
      "@anywhererace/store/*": ["packages/store/src/*"],
      "@anywhererace/ui": ["packages/ui/src/index.ts"],
      "@anywhererace/ui/*": ["packages/ui/src/*"]
    }
  }
}
