# MapTiler API key for the basemap.
#
# Without this the app still runs, but on a blank background instead of a real
# map. Get a free key at https://cloud.maptiler.com/account/keys/ and put it in
# a local .env.local file (which is gitignored).
#
# This key ships to the browser and is therefore public. Restrict it by HTTP
# referrer in the MapTiler dashboard to the domains that should use it, e.g.
# localhost and anywhererace.banton-digital.com.
VITE_MAPTILER_KEY=
